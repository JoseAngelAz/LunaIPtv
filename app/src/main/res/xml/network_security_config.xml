<?xml version="1.0" encoding="utf-8"?>
<!-- Network security configuration for LunaIPtv.
     IPTV providers often stream over plain HTTP, so cleartext is allowed.
     In debug builds, user-installed CA certificates are also trusted (useful for local proxying). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
